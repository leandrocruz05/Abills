rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════════════════
    // FINANZAS - Requiere autenticación
    // ═══════════════════════════════════════════════════════════════
    
    // Regla para datos de usuarios
    match /users/{userId} {
      // Solo el usuario autenticado puede leer/escribir sus propios datos
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Colección de finanzas del usuario
      match /finanzas/{mesAno} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Colección de configuración del usuario (categorías y cuentas)
      match /configuracion/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // ═══════════════════════════════════════════════════════════════
    // SUPERMERCADO - Acceso público para uso personal/familiar
    // ═══════════════════════════════════════════════════════════════
    
    // Productos del supermercado
    match /productos/{productId} {
      allow read, write: if true;
    }
    
    // Stock de productos
    match /stock/{stockId} {
      allow read, write: if true;
    }
    
    // Precios por supermercado
    match /precios/{precioId} {
      allow read, write: if true;
    }
    
    // Descuentos configurados
    match /descuentos/{descuentoId} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════════════════════════════
    // TAREAS - Acceso público para uso personal/familiar
    // ═══════════════════════════════════════════════════════════════
    
    match /tareas/{tareaId} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════════════════════════════
    // Denegar acceso a todo lo demás por defecto
    // ═══════════════════════════════════════════════════════════════
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
